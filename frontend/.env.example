# Deal Companion frontend (Next.js) — environment variables
#
# Local dev: copy this file to .env.local and fill in the values.
# Production: set these in the Vercel project's "Environment Variables"
# panel. NEXT_PUBLIC_* vars are inlined into the client bundle at build
# time; everything else is server-only and only available in
# server components, route handlers, server actions, and Inngest functions.

# ---------------------------------------------------------------------------
# Supabase — public keys (browser-safe)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=             # https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # JWT-issuing anon key

# Worker base URL the browser hits via the /api/v1 rewrite.
NEXT_PUBLIC_API_URL=                  # https://cognisuite-worker.up.railway.app

# Sentry browser DSN (optional — error tracking). Leave blank to disable.
NEXT_PUBLIC_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Server-only (NEVER prefix these with NEXT_PUBLIC_)
# ---------------------------------------------------------------------------
# Service-role key used by Inngest functions for service-side writes that
# need to bypass RLS (e.g. updating meetings.status from the pipeline).
# Treat as a hard secret — leaking this exposes every customer's data.
SUPABASE_SERVICE_ROLE_KEY=

# Inngest. INNGEST_EVENT_KEY signs outbound events; INNGEST_SIGNING_KEY
# verifies inbound webhook deliveries. The /api/inngest route fails at
# import time in production if SIGNING_KEY is missing.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Shared secret between Inngest functions and the worker's /api/v1/internal/*
# routes. Must match the worker's WORKER_INTERNAL_TOKEN.
WORKER_INTERNAL_TOKEN=

# Worker base URL used by Inngest functions (server-side fetches). Usually
# identical to NEXT_PUBLIC_API_URL but kept separate so server traffic can
# point at an internal hostname when desired.
API_BACKEND_URL=                      # https://cognisuite-worker.up.railway.app
