# CogniSuite — environment variables
#
# Copy to .env for local dev. The FastAPI worker (Railway) reads this file
# directly; the frontend reads only the NEXT_PUBLIC_* values at build time
# and the rest via Vercel project settings. Do NOT commit .env.

# ---------------------------------------------------------------------------
# Worker-owned data layer (SQLite migration — see backend/SQLITE_MIGRATION.md)
# ---------------------------------------------------------------------------
SQLITE_DB_PATH=/data/app.db          # SQLite file (Fly volume in prod; ./app.db locally)
STORAGE_ROOT=/data/storage           # object-storage root (replaces Supabase Storage)
STORAGE_SIGNING_KEY=                 # HMAC key for signed upload/download URLs (random; distinct in prod)
SESSION_JWT_SECRET=                  # signs the session cookie (random; distinct in prod)
SESSION_COOKIE_NAME=cogni_session

# Litestream backup of the SQLite file → object storage. Leave REPLICA_URL
# empty to disable backups (dev only). REQUIRED in production.
LITESTREAM_REPLICA_URL=              # e.g. s3://my-bucket/cogni/app.db
LITESTREAM_ACCESS_KEY_ID=            # replica credentials (or AWS_* / S3-compatible)
LITESTREAM_SECRET_ACCESS_KEY=

# ---------------------------------------------------------------------------
# Supabase — ONLY needed for the one-time data cutover (scripts/cutover.sh).
# After migrating, these can be removed; the app no longer reads Supabase
# except dependencies.py's transition JWT-verify (drop once everyone re-logs in).
# ---------------------------------------------------------------------------
SUPABASE_URL=                        # https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=           # server-only — used by the data migration to export rows
SUPABASE_JWT_SECRET=                 # transition: verify still-valid Supabase-issued tokens

# Frontend (Vercel project env). NEXT_PUBLIC_API_URL must point at the worker;
# the NEXT_PUBLIC_SUPABASE_* values are no longer used by the migrated frontend.
NEXT_PUBLIC_API_URL=                 # FastAPI worker — e.g. https://cognisuite-worker.fly.dev

# ---------------------------------------------------------------------------
# LLM: Fireworks (default for all tasks)
# ---------------------------------------------------------------------------
FIREWORKS_API_KEY=

# Per-task model overrides (optional — defaults live in llm/router.py).
# Format: "<provider>/<model>". providers: fireworks | anthropic
LLM_MODEL_FOR_SUMMARIZATION=
LLM_MODEL_FOR_ACTION_ITEMS=
LLM_MODEL_FOR_QA_RAG=
LLM_MODEL_FOR_IC_MEMO=
LLM_MODEL_FOR_EMBEDDING=

# Q&A context-first budgets (optional). A meeting/deal whose full transcript(s)
# + document text fit within this many estimated tokens is answered by feeding
# the whole corpus to a cheap model (full recall, no retrieval); above it, Q&A
# falls back to RAG. Sized for headroom inside a ~32k-token context window.
QA_MEETING_FULL_MAX_TOKENS=24000
QA_DEAL_FULL_MAX_TOKENS=24000

# ---------------------------------------------------------------------------
# LLM: Claude (opt-in only — costs real money)
# ---------------------------------------------------------------------------
PREMIUM_LLM_ENABLED=false            # must be "true" to route any task to Claude
ANTHROPIC_API_KEY=                   # only needed if PREMIUM_LLM_ENABLED=true

# ---------------------------------------------------------------------------
# Transcription & bots
# ---------------------------------------------------------------------------
DEEPGRAM_API_KEY=
RECALL_API_KEY=
RECALL_WEBHOOK_SECRET=               # HMAC secret for verifying Recall webhooks
RECALL_REGION=us-west-2              # Recall tokens are region-scoped; must match the region the key was issued for (us-west-2, us-east-1, eu-central-1, ap-northeast-1)

# ---------------------------------------------------------------------------
# Async jobs — Inngest
# ---------------------------------------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---------------------------------------------------------------------------
# Integrations — OAuth clients
# ---------------------------------------------------------------------------
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=

# Single Microsoft OAuth app covers Teams + Outlook + Calendar.
# TEAMS_* aliases are still honoured for backwards compatibility.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_WEBHOOK_SECRET=            # clientState for Graph change notifications

# Google OAuth app — Calendar scopes only (Meet URLs are embedded in events).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Public URLs used to build OAuth redirect_uri values and bounce users back.
# FRONTEND_URL is where we 302 the browser after the worker stores tokens.
# PUBLIC_API_URL is the worker's own public URL — the OAuth provider POSTs
# the callback to `${PUBLIC_API_URL}/api/v1/integrations/{platform}/callback`.
FRONTEND_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Worker crypto
# ---------------------------------------------------------------------------
# Fernet key used to encrypt stored OAuth refresh tokens.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Shared secret between Inngest functions (Vercel) and the worker (Fly.io).
# Every /api/v1/internal/* request must send this in the X-Internal-Token header.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Same value goes in Vercel as WORKER_INTERNAL_TOKEN.
WORKER_INTERNAL_TOKEN=

# ---------------------------------------------------------------------------
# Observability (optional but recommended in prod)
# ---------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
APP_ENV=development                  # development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
# Optional regex applied in addition to CORS_ORIGINS. Use this for Vercel
# preview deployments and branch URLs which get unique origins per push.
# Example: ^https://.*\.vercel\.app$  (or scope to your project for safety:
# ^https://ai-notetaker-finance(-[a-z0-9-]+)?\.vercel\.app$)
CORS_ORIGIN_REGEX=
