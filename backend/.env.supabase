# Deal Companion – Supabase + Railway + Upstash Environment Template
# Copy to .env and fill in your values.

APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# Demo mode (set to true for local dev without Supabase Auth)
DEMO_MODE=false
DEMO_JWT_SECRET=change-me-to-a-random-string

# ── Supabase PostgreSQL ─────────────────────────────────────────────
# Get from: Supabase Dashboard > Project Settings > Database > Connection string (URI)
# Use the "Transaction" connection pooler (port 6543) for serverless/short-lived connections
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Supabase Auth ───────────────────────────────────────────────────
# Get from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
# Get from: Supabase Dashboard > Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=

# ── Upstash Redis ───────────────────────────────────────────────────
# Get from: Upstash Console > Redis > Database > REST URL
# Use the rediss:// (TLS) URL
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ── S3-Compatible Storage ───────────────────────────────────────────
# Option A: Cloudflare R2
# S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# Option B: AWS S3 (leave S3_ENDPOINT_URL blank)
S3_BUCKET_NAME=dealwise-dev
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── API Keys ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=
