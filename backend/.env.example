# Database
DATABASE_URL=postgresql+asyncpg://dealwise:localdev@localhost:5432/dealwise

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS S3 / MinIO
S3_BUCKET_NAME=dealwise-local
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# AWS Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_DOMAIN=dealwise.auth.us-east-1.amazoncognito.com

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Deepgram
DEEPGRAM_API_KEY=...

# Encryption
TOKEN_ENCRYPTION_KEY=generate-with-fernet

# App
APP_ENV=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=http://localhost:3000

# Demo mode (bypasses Cognito auth for demo/dev deployments)
DEMO_MODE=true
DEMO_JWT_SECRET=change-this-to-a-random-secret
